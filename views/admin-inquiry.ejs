<%- include('partials/admin-header') %>

<!-- Top Back Link and Eyebrow -->
<div style="margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between;">
  <a href="/admin/dashboard" style="font-size: 13px; font-weight: 600; color: var(--text-secondary); display: flex; align-items: center; gap: 6px; transition: color 0.15s ease;" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-secondary)'">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12,19 5,12 12,5"></polyline></svg>
    Back to dashboard Overview
  </a>
  <div class="eyebrow" style="margin-bottom: 0;">Inquiry Details</div>
</div>

<div class="inquiry-detail-grid">
  
  <!-- Left Side: Main details and Project Inquiry Info -->
  <div style="display: flex; flex-direction: column; gap: 24px;">
    
    <!-- Detail Card -->
    <div class="glass-card" style="padding: 32px; background: #ffffff; border: 1px solid rgba(0, 0, 0, 0.05); box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.01);">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; flex-wrap: wrap; gap: 12px;">
        <div>
          <div style="font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Inquiry ID: #<%= String(inquiry.id).padStart(4, '0') %></div>
          <h2 style="font-size: 26px; font-family: var(--font-title); font-weight: 800; color: var(--text-primary); margin-top: 4px;">"<%= inquiry.job_title || 'AI Project Inquiry' %>"</h2>
        </div>
        <div>
          <span class="status-pill <%= inquiry.status === 'New' ? 'new' : inquiry.status === 'In progress' ? 'progress' : inquiry.status === 'Replied' ? 'replied' : 'closed' %>" style="font-size: 12px; padding: 4px 12px;">
            Status: <%= inquiry.status %>
          </span>
        </div>
      </div>

      <div class="divider" style="margin-bottom: 24px;"></div>

      <div class="detail-info-list">
        <span class="detail-info-label">Full Name</span>
        <span class="detail-info-value" style="color: var(--text-primary);"><%= inquiry.name %></span>

        <span class="detail-info-label">Email Address</span>
        <span class="detail-info-value"><a href="mailto:<%= inquiry.email %>" style="color: var(--accent-blue); text-decoration: none; font-weight: 600; border-bottom: 1px dashed var(--accent-blue);"><%= inquiry.email %></a></span>

        <span class="detail-info-label">Phone Number</span>
        <span class="detail-info-value" style="color: var(--text-primary); font-family: monospace; font-size: 13px;"><%= inquiry.phone %></span>

        <span class="detail-info-label">Company / School</span>
        <span class="detail-info-value" style="color: var(--text-primary);"><%= inquiry.company || 'Not Specified' %></span>

        <span class="detail-info-label">Country</span>
        <span class="detail-info-value" style="color: var(--text-primary);"><%= inquiry.country || 'Not Specified' %></span>

        <span class="detail-info-label">Submitted On</span>
        <% 
          const date = new Date(inquiry.created_at);
          const formattedDate = date.toLocaleDateString('en-US', { 
            month: 'long', 
            day: 'numeric', 
            year: 'numeric', 
            hour: '2-digit', 
            minute: '2-digit' 
          });
        %>
        <span class="detail-info-value" style="color: var(--text-primary);"><%= formattedDate %></span>
      </div>

      <div class="divider" style="margin-top: 24px; margin-bottom: 24px;"></div>

      <div>
        <h4 style="font-size: 12px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 10px; font-weight: 700;">Inquiry message</h4>
        <div style="background-color: #f8fafc; border: 1px solid rgba(0,0,0,0.04); padding: 20px; border-radius: 12px; font-size: 14px; line-height: 1.7; color: var(--text-primary); white-space: pre-line; border-left: 4px solid var(--accent-blue);">
          <%= inquiry.job_details %>
        </div>
      </div>
    </div>

    <!-- Activity Log Timeline -->
    <div class="glass-card" style="padding: 24px; background: #ffffff; border: 1px solid rgba(0, 0, 0, 0.05); box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.01);">
      <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 18px; color: var(--text-primary); font-family: var(--font-title);">Inquiry Activity Log</h3>
      <div class="activity-list">
        <div class="activity-item">
          <span class="activity-dot green"></span>
          <span class="activity-text">Inquiry received and stored securely in local SQLite engine (FR-02)</span>
          <span class="activity-time">Just now</span>
        </div>
        <div class="activity-item">
          <span class="activity-dot blue"></span>
          <span class="activity-text">Assigned to developer: <strong><%= inquiry.assigned_to %></strong></span>
          <span class="activity-time">Just now</span>
        </div>
        <% if (inquiry.status !== 'New') { %>
          <div class="activity-item">
            <span class="activity-dot purple"></span>
            <span class="activity-text">Inquiry status was updated to: <strong style="color: var(--accent-purple);"><%= inquiry.status %></strong></span>
            <span class="activity-time">Just now</span>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Side: Action and Workflow Panels -->
  <div style="display: flex; flex-direction: column; gap: 24px;">
    
    <!-- Status Modifier -->
    <div class="glass-card" style="padding: 24px; background: #ffffff; border: 1px solid rgba(0, 0, 0, 0.05); box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.01);">
      <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 14px; color: var(--text-primary); font-family: var(--font-title);">Update Inquiry Status</h3>
      
      <form action="/admin/inquiries/<%= inquiry.id %>/status" method="POST">
        <div class="form-group" style="margin-bottom: 16px;">
          <label for="status" style="font-size: 11px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Status Selector</label>
          <select name="status" id="status" class="form-control" style="background-color: #ffffff; border-radius: 8px; font-size: 13px; font-weight: 600; padding: 10px; width: 100%; border: 1px solid var(--border-color);">
            <option value="New" <%= inquiry.status === 'New' ? 'selected' : '' %>>New</option>
            <option value="In progress" <%= inquiry.status === 'In progress' ? 'selected' : '' %>>In Progress</option>
            <option value="Replied" <%= inquiry.status === 'Replied' ? 'selected' : '' %>>Replied</option>
            <option value="Closed" <%= inquiry.status === 'Closed' ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-sm" style="width: 100%; padding: 10px; border-radius: 8px; font-weight: 600;">Save changes</button>
      </form>
    </div>

    <!-- Email Drafter Box -->
    <div class="glass-card" style="padding: 24px; background: #ffffff; border: 1px solid rgba(0, 0, 0, 0.05); box-shadow: 0 4px 6px -1px rgba(15, 23, 42, 0.01); display: flex; flex-direction: column; gap: 14px;">
      <h3 style="font-size: 16px; font-weight: 700; color: var(--text-primary); font-family: var(--font-title); margin-bottom: 2px;">Draft Email Reply</h3>
      
      <div class="form-group" style="margin-bottom: 0;">
        <label for="reply-text" style="font-size: 11px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Email body message</label>
        <textarea class="form-control" id="reply-text" style="height: 130px; font-size: 12px; line-height: 1.5; padding: 10px 12px; background-color: #ffffff; border-radius: 8px;" placeholder="Hi <%= inquiry.name.split(' ')[0] %>, thanks for reaching out. We would love to schedule a Discovery Call..."></textarea>
      </div>
      
      <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 6px;">
        <button class="btn btn-secondary btn-sm" style="border-radius: 8px; padding: 8px 14px; font-weight: 600;" onclick="alert('Draft saved locally.')">Save draft</button>
        <button class="btn btn-primary btn-sm" style="border-radius: 8px; padding: 8px 14px; font-weight: 600; background: var(--grad-green);" onclick="alert('Sending email simulation through Node.js...')">Send reply →</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
