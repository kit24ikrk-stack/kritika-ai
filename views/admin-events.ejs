<%- include('partials/admin-header') %>

<div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 32px;">
  <div>
    <h1 style="font-size: 32px; font-weight: 800; font-family: var(--font-title); color: var(--text-primary); margin-top: 4px;">Events & Meetups</h1>
    <div style="margin-top: 4px; color: var(--text-secondary); font-size: 14px;">Schedule and manage community events.</div>
  </div>
  <button class="btn btn-primary btn-sm">Create new event</button>
</div>

<div class="glass-card" style="padding: 60px; text-align: center; background: #ffffff; border: 1px solid rgba(0,0,0,0.05);">
  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto 16px; color: var(--text-muted);"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
  <h3 style="font-size: 18px; color: var(--text-primary); margin-bottom: 8px;">Events Module</h3>
  <p style="color: var(--text-secondary); font-size: 14px; max-width: 400px; margin: 0 auto;">Event registration and calendar integration is under development. Please use third-party tools for now.</p>
</div>

<%- include('partials/admin-footer') %>
