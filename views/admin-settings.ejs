<%- include('partials/admin-header') %>

<div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 32px;">
  <div>
    <h1 style="font-size: 32px; font-weight: 800; font-family: var(--font-title); color: var(--text-primary); margin-top: 4px;">Settings</h1>
    <div style="margin-top: 4px; color: var(--text-secondary); font-size: 14px;">Manage account and system preferences.</div>
  </div>
</div>

<div class="glass-card" style="background: #ffffff; border: 1px solid rgba(0,0,0,0.05); padding: 32px;">
  <h3 style="font-size: 18px; margin-bottom: 24px; border-bottom: 1px solid var(--border-color); padding-bottom: 12px;">Account Details</h3>
  
  <div style="display: grid; gap: 20px; max-width: 400px;">
    <div class="form-group" style="margin-bottom: 0;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Email address</label>
      <input type="email" class="form-control" value="<%= session.adminUser || 'admin@kritika.ai' %>" disabled style="background: var(--bg-surface);">
    </div>
    
    <div class="form-group" style="margin-bottom: 0;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Current Password</label>
      <input type="password" class="form-control" value="********" disabled style="background: var(--bg-surface);">
    </div>

    <button class="btn btn-secondary" style="width: fit-content; margin-top: 8px;">Update Password</button>
  </div>
</div>

<%- include('partials/admin-footer') %>
