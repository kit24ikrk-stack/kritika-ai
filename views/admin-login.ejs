<%- include('partials/header') %>

<main class="main-content" style="display: flex; align-items: center; justify-content: center; min-height: 70vh;">
  <div class="admin-login-container">
    <div class="glass-card admin-login-card">
      <div style="text-align: center; margin-bottom: 28px;">
        <div class="logo-icon" style="width: 52px; height: 52px; font-size: 24px; margin: 0 auto 16px; border-radius: 12px; font-family: var(--font-title);">K</div>
        <h2 style="font-size: 24px; font-family: var(--font-title); font-weight: 800; color: var(--text-primary);">Admin Panel</h2>
        <div style="margin-top: 8px; color: var(--text-secondary); font-size: 13px;">Sign in to manage inquiries</div>
      </div>

      <!-- Login Error Alerts -->
      <% if (errorMsg === 'invalid') { %>
        <div style="padding: 12px; background-color: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--accent-red); border-radius: 8px; font-size: 13px; text-align: center; margin-bottom: 20px; font-weight: 500;">
          Invalid email username or password.
        </div>
      <% } else if (errorMsg === 'missing') { %>
        <div style="padding: 12px; background-color: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--accent-red); border-radius: 8px; font-size: 13px; text-align: center; margin-bottom: 20px; font-weight: 500;">
          Please provide both email and password.
        </div>
      <% } else if (errorMsg === 'server') { %>
        <div style="padding: 12px; background-color: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: var(--accent-red); border-radius: 8px; font-size: 13px; text-align: center; margin-bottom: 20px; font-weight: 500;">
          Database error. Falling back to local engine.
        </div>
      <% } %>

      <form action="/admin/login" method="POST" style="display: flex; flex-direction: column; gap: 18px;">
        <div class="form-group" style="margin-bottom: 0;">
          <label for="email" style="font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Email address</label>
          <input type="email" class="form-control" name="email" id="email" required placeholder="admin@kritika.ai" style="background-color: #ffffff; border-radius: 10px; padding: 12px 16px;">
        </div>

        <div class="form-group" style="margin-bottom: 0;">
          <label for="password" style="font-size: 12px; font-weight: 600; color: var(--text-secondary); margin-bottom: 6px;">Password</label>
          <input type="password" class="form-control" name="password" id="password" required placeholder="••••••••" style="background-color: #ffffff; border-radius: 10px; padding: 12px 16px;">
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 12px; margin-top: 4px;">
          <label class="form-checkbox">
            <input type="checkbox" style="accent-color: var(--accent-blue);">
            <span style="font-weight: 500; color: var(--text-secondary); margin-left: 6px;">Remember session</span>
          </label>
          <span style="color: var(--accent-blue); font-weight: 600; cursor: pointer;" onclick="alert('Please check seed.js for default credentials.')">Reset password</span>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px; border-radius: 10px; font-weight: 600; font-size: 14px; margin-top: 8px;">Sign in to Account</button>
      </form>
      
      <div style="margin-top: 24px; text-align: center; border-top: 1px solid var(--border-color); padding-top: 16px;">
        <a href="/" style="font-size: 12px; color: var(--text-muted); font-weight: 500; display: inline-flex; align-items: center; gap: 4px; transition: color 0.2s;" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12,19 5,12 12,5"></polyline></svg>
          Back to website
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
