<%- include('partials/admin-header') %>

<div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 32px;">
  <div>
    <h1 style="font-size: 32px; font-weight: 800; font-family: var(--font-title); color: var(--text-primary); margin-top: 4px;">Gallery</h1>
    <div style="margin-top: 4px; color: var(--text-secondary); font-size: 14px;">Manage your studio's images and media assets.</div>
  </div>
  <button class="btn btn-primary btn-sm">Upload new media</button>
</div>

<div class="glass-card" style="padding: 60px; text-align: center; background: #ffffff; border: 1px solid rgba(0,0,0,0.05);">
  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto 16px; color: var(--text-muted);"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
  <h3 style="font-size: 18px; color: var(--text-primary); margin-bottom: 8px;">Gallery Module</h3>
  <p style="color: var(--text-secondary); font-size: 14px; max-width: 400px; margin: 0 auto;">Media asset management is currently under development. Uploaded files are served from the static directory directly for now.</p>
</div>

<%- include('partials/admin-footer') %>
