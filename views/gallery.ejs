<%- include('partials/header') %>

<main class="main-content">
  <div class="page-intro">
    <h1>Events & Gallery</h1>
    <p>Talks, meetups, and behind-the-scenes moments from the Kathmandu studio.</p>
  </div>

  <!-- Upcoming Events -->
  <section class="events-section">
    <h2>Upcoming Events</h2>
    
    <div class="events-list">
      <div class="event-card-clean">
        <div class="event-date-box">
          <span class="event-date-day">12</span>
          <span class="event-date-month">Jun</span>
        </div>
        <div class="event-info">
          <h3>AI for small teams — Kathmandu meetup</h3>
          <p>Patan Lab · Free entry</p>
        </div>
        <button class="btn btn-primary btn-sm">RSVP</button>
      </div>

      <div class="event-card-clean">
        <div class="event-date-box">
          <span class="event-date-day">28</span>
          <span class="event-date-month">Jun</span>
        </div>
        <div class="event-info">
          <h3>Workshop: Writing AI Project Briefs</h3>
          <p>Zoom Session · NPR 500</p>
        </div>
        <button class="btn btn-primary btn-sm">RSVP</button>
      </div>
    </div>
  </section>

