<%- include('partials/admin-header') %>

<div style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 32px;">
  <div>
    <h1 style="font-size: 32px; font-weight: 800; font-family: var(--font-title); color: var(--text-primary); margin-top: 4px;">Reviews</h1>
    <div style="margin-top: 4px; color: var(--text-secondary); font-size: 14px;">Monitor and manage client feedback.</div>
  </div>
</div>

<div class="data-table-container">
  <div class="table-header">
    <h3>Client Feedback</h3>
  </div>

  <div class="table-body">
    <% if (reviews && reviews.length > 0) { %>
      <% reviews.forEach(review => { %>
        <div class="table-row" style="align-items: flex-start; padding: 16px;">
          
          <div style="display: flex; flex-direction: column; gap: 4px; width: 100px;">
            <div style="color: #fbbf24; font-size: 14px;">
              <% for (let i = 0; i < review.rating; i++) { %>★<% } %>
              <% for (let i = review.rating; i < 5; i++) { %>☆<% } %>
            </div>
            <span style="font-size: 12px; color: var(--text-secondary);">
              <%= new Date(review.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </span>
          </div>
          
          <div class="inquiry-info" style="flex: 1;">
            <span class="inquiry-name" style="margin-bottom: 4px;"><%= review.name %> <span style="font-weight: 400; color: var(--text-secondary); font-size: 12px; margin-left: 4px;"><%= review.role %></span></span>
            <p style="font-size: 14px; color: var(--text-secondary); line-height: 1.5;">"<%= review.comment %>"</p>
          </div>
          
          <div style="display: flex; gap: 8px;">
            <button class="btn btn-secondary btn-sm" style="border-radius: 6px; padding: 4px 10px;">Hide</button>
            <button class="btn btn-secondary btn-sm" style="border-radius: 6px; padding: 4px 10px; color: var(--accent-red);">Delete</button>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div style="padding: 40px; text-align: center; color: var(--text-muted); font-size: 14px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom: 8px; opacity: 0.5;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        <div>No reviews submitted yet.</div>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/admin-footer') %>
